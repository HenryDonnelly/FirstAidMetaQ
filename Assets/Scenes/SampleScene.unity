    - target: {fileID: 2859147190401906338, guid: b16424dcc3deba241b1457370a8e5b5e, type: 3}
      propertyPath: m_text
      value: "Welcome to QuestQCPR! This is a hands-only CPR training app. To begin,
        please align the Virtual manikin over your real manikin (or the floor if
        you dont own one) and press the \"Lock position\" Button. \n\nIf you would
        like to learn how to perform CPR, play the instructional video for help.
        \n\nTo exit this window, simply press the x located in the top left"
